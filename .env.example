# ─────────────────────────────────────────────────────────────────────
# .env.example — Plantilla de configuración de Sabueso de Licitaciones
# ─────────────────────────────────────────────────────────────────────
# Copia este archivo a .env y rellena los valores reales.
# El .env NUNCA se sube a GitHub (está en .gitignore). Este .example SÍ.
# ─────────────────────────────────────────────────────────────────────

# ── IA: Gemini (obligatoria) ──────────────────────────────────────────
# Clave de API de Google AI Studio.
GEMINI_API_KEY=
# Modelo de Gemini a usar (si se omite, usa el valor por defecto del código).
GEMINI_MODEL=gemini-2.5-flash-lite

# ── Notificaciones: Resend (obligatoria para el Step 5) ───────────────
# Clave de API de Resend (empieza por re_). Se obtiene en resend.com.
RESEND_API_KEY=
# Remitente de los emails. En desarrollo, deja el de pruebas de Resend.
# En producción, cámbialo por tu dominio verificado: "Sabueso <avisos@tudominio.es>"
EMAIL_FROM=Sabueso <onboarding@resend.dev>
# Interruptor de notificaciones: true para enviar, false para desactivar.
EMAIL_NOTIFICACIONES_ACTIVO=true

# ── Base de datos (opcional) ──────────────────────────────────────────
# Si se omite, usa SQLite local en database/sabueso.db
# DATABASE_URL=sqlite:///database/sabueso.db

# ── Feed PCSP (opcional) ──────────────────────────────────────────────
# Si se omiten, usan los valores por defecto del config.py
# PCSP_FEED_COMPLETO=
# ACTIVE_FEED=completo

# ── HTTP / Scraping (opcional) ────────────────────────────────────────
# REQUEST_TIMEOUT=30
# REQUEST_DELAY_SECONDS=1.0
# MAX_RETRIES=3
# MAX_LICITACIONES_POR_RUN=20

# ── Logging (opcional) ────────────────────────────────────────────────
# LOG_LEVEL=INFO

# ── Motor de relevancia (opcional) ────────────────────────────────────
# SCORE_RELEVANCIA_MINIMO=60
# TEXTO_MINIMO_CARACTERES=100